{
  "name": "numbat-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite preview",
    "check": "tsc -p tsconfig.json && tsc -p tsconfig.node.json",
    "prebuild": "tsx scripts/fetch-wasm.ts && tsx scripts/fetch-rates.ts && tsx scripts/generate-icons.ts",
    "build": "npm run check && vite build && echo 'calcite.mojzu.net' > dist/CNAME",
    "clean": "rm -rf dist",
    "test": "playwright test",
    "test:install": "playwright install chromium",
    "deploy": "gh-pages -d dist"
  },
  "devDependencies": {
    "@playwright/test": "^1.0.0",
    "@resvg/resvg-js": "^2.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.0.0",
    "gh-pages": "^6.3.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^1.0.0",
    "vite-plugin-top-level-await": "^1.0.0",
    "vite-plugin-wasm": "^3.0.0"
  }
}
